generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id             String            @id @db.Uuid
  email          String            @unique
  displayName    String?
  avatarUrl      String?
  college        String?
  graduationYear Int?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  memberships    ChallengeMember[]
  roomsCreated   ChallengeRoom[]
  sessions       ExamSession[]
}

model Question {
  id            String   @id @default(uuid()) @db.Uuid
  section       String
  topic         String
  difficulty    String
  questionText  String
  options       String[]
  correctOption String
  explanation   String?
  createdAt     DateTime @default(now())
}

model ExamConfiguration {
  id            String          @id @default(uuid()) @db.Uuid
  name          String
  duration      Int
  sectionOrder  String[]
  sectionConfig Json
  isDefault     Boolean         @default(false)
  createdAt     DateTime        @default(now())
  rooms         ChallengeRoom[]
  sessions      ExamSession[]
}

model ExamSession {
  id              String            @id @default(uuid()) @db.Uuid
  userId          String            @db.Uuid
  configId        String            @db.Uuid
  type            String
  status          String
  startedAt       DateTime          @default(now())
  completedAt     DateTime?
  answers         Json
  questionsOrder  String[]
  score           Float?
  accuracy        Float?
  timeTaken       Int?
  sectionScores   Json?
  challengeMember ChallengeMember?
  config          ExamConfiguration @relation(fields: [configId], references: [id])
  user            Profile           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChallengeRoom {
  id             String            @id @default(uuid()) @db.Uuid
  roomCode       String            @unique
  configId       String            @db.Uuid
  creatorId      String            @db.Uuid
  status         String
  questionsOrder String[]
  createdAt      DateTime          @default(now())
  startedAt      DateTime?
  members        ChallengeMember[]
  config         ExamConfiguration @relation(fields: [configId], references: [id])
  creator        Profile           @relation(fields: [creatorId], references: [id])
}

model ChallengeMember {
  id        String        @id @default(uuid()) @db.Uuid
  roomId    String        @db.Uuid
  userId    String        @db.Uuid
  status    String
  joinedAt  DateTime      @default(now())
  sessionId String?       @unique @db.Uuid
  room      ChallengeRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  session   ExamSession?  @relation(fields: [sessionId], references: [id])
  user      Profile       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
}
